{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/myapp-.txt",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "VerificationCode": {
    "ExpirationTimeInMinutes": 3,
    "MaxFailedAttempts": 10
  },
  "Token": {
    "ExpirationTimeInHours": 24
  },
  "EmailConfiguration": {
    "WelcomeSubject": "Bienvenido a Tienda UCN",
    "From": "Tienda - UCN <onboarding@resend.dev>",
    "VerificationSubject": "Código de Verificación"
  },
  "User": {
    "Genders": [
      "Masculino",
      "Femenino",
      "Otro"
    ],
    "AdminUser": {
      "Name": "Admin TiendaUCN",
      "Email": "admin@tiendaucn.cl",
      "Rut": "11111111-1",
      "PhoneNumber": "+569 0000-0000",
      "BirthDate": "1990-01-01",
      "Gender": "Otro",
      "Password": "AdminPassword123!"
    },
    "RandomUserPassword": "UserPassword123!"
  },
  "Jobs": {
    "CronJobDeleteUnconfirmedUsers": "30 20 * * *",
    "CronJobDeleteExpiredTokens": "30 20 * * * ",
    "TimeZone": "Pacific SA Standard Time",
    "DaysToDeleteUnverifiedAccount": 7
  },
  "HangfireDashboard": {
    "StatsPollingInterval": 7000,
    "DashboardTitle": "Panel de Control de Hangfire",
    "DashboardPath": "/hangfire",
    "DisplaystorageConnectionstring": false
  },
  "Products": {
    "ImageAllowedExtensions": [
      ".jpg",
      ".jpeg",
      ".png",
      ".webp"
    ],
    "ImageMaxSizeInBytes": 5242880,
    "TransformationWidth": 1000,
    "TransformationCrop": "scale",
    "TransformationQuality": "auto:best",
    "TransformationFetchFormat": "auto"
  }
}