{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/myapp-.txt",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "VerificationCode": {
    "ExpirationTimeInMinutes": 3,
    "MaxFailedAttempts": 10
  },
  "Token": {
    "ExpirationTimeInHours": 24
  },
  "EmailConfiguration": {
    "WelcomeSubject": "Bienvenido a Tienda UCN",
    "From": "Tienda - UCN <onboarding@resend.dev>",
    "VerificationSubject": "Código de Verificación"
  },
  "User": {
    "Genders": [
      "Masculino",
      "Femenino",
      "Otro"
    ],
    "AdminUser": {
      "Name": "Admin TiendaUCN",
      "Email": "admin@tiendaucn.cl",
      "Rut": "11111111-1",
      "PhoneNumber": "+569 0000-0000",
      "BirthDate": "1990-01-01",
      "Gender": "Otro",
      "Password": "AdminPassword123!"
    },
    "RandomUserPassword": "UserPassword123!"
  }
}